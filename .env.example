# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/securis_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Microsoft Authentication
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret
MICROSOFT_TENANT_ID=your_tenant_id
MICROSOFT_REDIRECT_URI=https://localhost:3000/api/auth/microsoft/callback

# Huffman Encryption Trees (JSON serialized)
HUFFMAN_TREE_BACK={"root":"placeholder"}
HUFFMAN_TREE_DB={"root":"placeholder"}

# Development
DEV_MODE=true
BYPASS_AUTH=true

# CORS
CORS_ORIGIN=https://localhost:5173

# SSL
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt
