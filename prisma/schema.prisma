generator client {
  provider     = "prisma-client"
  output       = "../src/core/database/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlserver"
}

// ============================================
// USERS TABLE
// ============================================
model User {
  id           Int      @id @default(autoincrement())
  microsoftId  String?  @unique @map("microsoft_id") @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  name         String?  @db.VarChar(255)
  qrSignature  String?  @map("qr_signature") @db.VarChar(500)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime

  // Relations
  documentsCreated    Document[]           @relation("DocumentAuthor")
  passwordResetTokens PasswordResetToken[]
  documentsReceived   DocumentRecipient[]  @relation("DocumentRecipient")

  @@map("users")
}

// ============================================
// PASSWORD RESET TOKENS TABLE
// ============================================
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.DateTime
  used      Boolean  @default(false) @db.Bit
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================
// DOCUMENTS TABLE
// ============================================
model Document {
  id               Int       @id @default(autoincrement())
  documentType     String    @map("document_type") @db.VarChar(20)
  category         String    @db.VarChar(20)
  status           String    @default("BORRADOR") @db.VarChar(20)
  subject          String    @db.VarChar(255)
  body             String    @db.NVarChar(Max)
  authorId         Int       @map("author_id")
  parentDocumentId Int?      @map("parent_document_id")
  sendDate         DateTime? @map("send_date") @db.DateTime
  pdfPath          String?   @map("pdf_path") @db.VarChar(500)
  qrSignature      String?   @map("qr_signature") @db.NVarChar(Max)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.DateTime

  // Relations
  author         User                 @relation("DocumentAuthor", fields: [authorId], references: [id])
  parentDocument Document?            @relation("DocumentReplies", fields: [parentDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        Document[]           @relation("DocumentReplies")
  recipients     DocumentRecipient[]
  attachments    DocumentAttachment[]

  @@index([authorId])
  @@index([status])
  @@map("documents")
}

// ============================================
// DOCUMENT RECIPIENTS TABLE
// ============================================
model DocumentRecipient {
  id          Int       @id @default(autoincrement())
  documentId  Int       @map("document_id")
  recipientId Int       @map("recipient_id")
  isRead      Boolean   @default(false) @map("is_read") @db.Bit
  readDate    DateTime? @map("read_date") @db.DateTime
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime

  // Relations
  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipient User     @relation("DocumentRecipient", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([documentId])
  @@index([recipientId])
  @@map("document_recipients")
}

// ============================================
// DOCUMENT ATTACHMENTS TABLE
// ============================================
model DocumentAttachment {
  id         Int      @id @default(autoincrement())
  documentId Int      @map("document_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  filePath   String   @map("file_path") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_attachments")
}
